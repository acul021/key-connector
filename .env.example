# Address the HTTP server binds to.
KC_BIND_ADDR=0.0.0.0:8081

# sqlx database URL. SQLite (?mode=rwc creates the file if missing) is the default;
# a Postgres/MySQL URL works too if you enable the matching sqlx feature.
KC_DATABASE_URL=sqlite:///data/keyconnector.db?mode=rwc

# Identity provider base URL. Issuer and RSA signing key are fetched from
# <authority>/.well-known/openid-configuration and refreshed periodically.
KC_IDENTITY_AUTHORITY=https://vault.example.com/identity

# Alternatively, configure a static key and issuer instead of the authority:
# KC_IDENTITY_PUBLIC_KEY_PATH=/data/identity.pub.pem
# KC_IDENTITY_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# KC_JWT_ISSUER=https://vault.example.com|login

# Base64 encoded 32 byte key used to encrypt the stored keys at rest, generate
# with `openssl rand -base64 32`. Losing it locks the affected users out of
# their vaults permanently, so back it up separately from the database.
# Provide exactly one of:
KC_ENCRYPTION_KEY_PATH=/run/secrets/kc_encryption_key
# KC_ENCRYPTION_KEY=

# Browser origins allowed to call the connector, comma separated. The web vault
# runs on a different origin than the connector, so set this to your vault URL.
# Leave empty to mirror any origin (auth is a bearer token, not a cookie).
KC_CORS_ALLOWED_ORIGINS=https://vault.example.com

# Optional log filter.
RUST_LOG=key_connector=info,tower_http=info
